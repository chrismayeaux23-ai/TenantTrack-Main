# Application
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/tenanttrack

# Session Security
SESSION_SECRET=replace_with_secure_random_string

# Replit (optional if running outside Replit)
REPLIT_DOMAINS=
REPLIT_DEPLOYMENT=
REPLIT_CONNECTORS_HOSTNAME=
REPL_ID=
REPL_IDENTITY=
WEB_REPL_RENEWAL=

# Storage (if using object storage)
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# Auth / issuer (if configured)
ISSUER_URL=
